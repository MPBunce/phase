# Local development environment variables.
# Copy to `.env` (gitignored) and fill in. Vite reads these at build time via
# loadEnv (see client/vite.config.ts); production/CI provides them as real env
# vars / GitHub secrets, which take precedence over any .env entry.

# --- Supabase cloud sync (optional) ---
# Leave blank to disable cloud sync entirely (the app falls back to file
# backup). Use the PUBLISHABLE key (sb_publishable_…) — never the secret key,
# which bypasses Row-Level Security and must not ship in the client bundle.
SUPABASE_URL=
SUPABASE_ANON_KEY=
